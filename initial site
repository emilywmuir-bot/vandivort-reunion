   detail:"Depart from hotel ~9 AM, arrive at the farm by 9:30. Lunch on your own afterward.", loc:"Northcut Farm", day:"Saturday — 5K & Farm Visit", ddate:"July 4"},
  {date:"2026-07-04", start:"18:00", end:"20:00", title:"Dinner in the Halle — with Snoopy Cake!",
   detail:"Last dinner night. Sheet cake and ice cream for the 4th.", day:"Saturday — 5K & Farm Visit", ddate:"July 4"},

  // Sunday, July 5
  {date:"2026-07-05", timeLabel:"Morning", noCal:true, title:"Departure — see you next year! 🎉",
   detail:"Safe travels home. Volunteers: boxes load at 8 AM.", day:"Sunday — Departure", ddate:"July 5"},
];
const LOCATION = "Bavarian Halle, Jackson, MO";
const TZ = "America/Chicago";

/* ---------- calendar helpers ---------- */
function compact(date, time){ return date.replace(/-/g,"") + "T" + time.replace(":","") + "00"; }
function googleUrl(ev){
  const p = new URLSearchParams({
    action:"TEMPLATE",
    text: ev.title + " — Vandivort Reunion",
    dates: compact(ev.date,ev.start) + "/" + compact(ev.date,ev.end),
    details: ev.detail,
    location: ev.loc || LOCATION,
    ctz: TZ
  });
  return "https://calendar.google.com/calendar/render?" + p.toString();
}
function downloadICS(ev){
  const ics = [
    "BEGIN:VCALENDAR","VERSION:2.0","PRODID:-//Vandivort Reunion//EN",
    "BEGIN:VEVENT",
    "UID:" + ev.date + ev.start.replace(":","") + "@vandivort-reunion",
    "DTSTAMP:" + compact(ev.date,ev.start),
    "DTSTART;TZID=" + TZ + ":" + compact(ev.date,ev.start),
    "DTEND;TZID=" + TZ + ":" + compact(ev.date,ev.end),
    "SUMMARY:" + ev.title + " — Vandivort Reunion",
    "DESCRIPTION:" + ev.detail.replace(/,/g,"\\,"),
    "LOCATION:" + (ev.loc || LOCATION).replace(/,/g,"\\,"),
    "END:VEVENT","END:VCALENDAR"
  ].join("\r\n");
  const blob = new Blob([ics], {type:"text/calendar"});
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = ev.title.replace(/[^a-z0-9]+/gi,"-").toLowerCase() + ".ics";
  document.body.appendChild(a); a.click();
  setTimeout(()=>{URL.revokeObjectURL(a.href); a.remove();}, 500);
}
function fmtTime(t){
  let [h,m] = t.split(":").map(Number);
  const ap = h >= 12 ? "PM" : "AM";
  h = h % 12 || 12;
  return h + (m ? ":" + String(m).padStart(2,"0") : "") + " " + ap;
}

/* ---------- render schedule ---------- */
(function renderSchedule(){
  const root = document.getElementById("scheduleRoot");
  const days = [];
  EVENTS.forEach(ev=>{
    let d = days.find(x=>x.date===ev.date);
    if(!d){ d = {date:ev.date, day:ev.day, ddate:ev.ddate, events:[]}; days.push(d); }
    d.events.push(ev);
  });
  days.forEach(d=>{
    const dayEl = document.createElement("div");
    dayEl.className = "day";
    dayEl.innerHTML = '<div class="day-head"><span class="dname">' + d.day +
      '</span><span class="ddate">' + d.ddate + '</span></div>';
    d.events.forEach(ev=>{
      const row = document.createElement("div");
      row.className = "event";
      const timeHtml = ev.noCal
        ? '<div class="etime mono">' + (ev.timeLabel || "") + '</div>'
        : '<div class="etime mono">' + fmtTime(ev.start) + '</div>';
      const stubHtml = ev.noCal ? '' :
        '<div class="event-stub">' +
          '<button class="calbtn">+ Add to calendar</button>' +
          '<div class="calmenu">' +
            '<a href="' + googleUrl(ev) + '" target="_blank" rel="noopener">Google Calendar ↗</a>' +
            '<button type="button" class="appleics">Apple / iPhone (.ics)</button>' +
          '</div>' +
        '</div>';
      row.innerHTML =
        '<div class="event-main">' +
          timeHtml +
          '<div class="etitle">' + ev.title + '</div>' +
          '<div class="edetail">' + ev.detail + '</div>' +
        '</div>' + stubHtml;
      if(!ev.noCal){
        const stub = row.querySelector(".event-stub");
        row.querySelector(".calbtn").addEventListener("click", ()=>{
          stub.classList.add("stub-open");
          row.querySelector(".calmenu").classList.add("open");
        });
        row.querySelector(".appleics").addEventListener("click", ()=> downloadICS(ev));
      }
      dayEl.appendChild(row);
    });
    root.appendChild(dayEl);
  });
})();

/* ============================================================
   SHARED STORAGE — message board + suggestion box.
   Backed by Netlify Functions + Netlify Database (Postgres).
   ============================================================ */
function esc(s){ const d=document.createElement("div"); d.textContent=s; return d.innerHTML; }
function stamp(iso){
  const d = new Date(iso);
  if(isNaN(d)) return "";
  return d.toLocaleString("en-US",{month:"short",day:"numeric",hour:"numeric",minute:"2-digit"});
}

/* ---------- message board ---------- */
const msgList = document.getElementById("msgList");
const msgStatus = document.getElementById("msgStatus");
const msgName = document.getElementById("msgName");
const msgText = document.getElementById("msgText");
const msgSend = document.getElementById("msgSend");
const msgAdmin = document.getElementById("msgAdmin");

const NAME_KEY = "vandivort-my-name";
const ADMIN_CODE_KEY = "vandivort-message-admin-code";
let messageAdminCode = "";
function loadName(){
  try{ const v = localStorage.getItem(NAME_KEY); if(v) msgName.value = v; }catch(e){}
}
function loadAdminCode(){
  try{ messageAdminCode = sessionStorage.getItem(ADMIN_CODE_KEY) || ""; }catch(e){}
  document.body.classList.toggle("admin-on", Boolean(messageAdminCode));
  msgAdmin.textContent = messageAdminCode ? "Exit delete mode" : "Admin delete mode";
}
async function loadMessages(){
  try{
    const res = await fetch("/api/messages");
    if(!res.ok) throw new Error("bad status");
    const items = await res.json();
    if(!Array.isArray(items) || items.length === 0){
      msgList.innerHTML = "";
      msgStatus.textContent = "No messages yet — be the first to say hi!";
      return;
    }
    msgList.innerHTML = items.map(m =>
      '<div class="msg"><div class="msg-meta"><b>' + esc(m.name || "Anonymous") + '</b> · ' +
      stamp(m.createdAt) + ' <button class="msg-delete" data-id="' + esc(String(m.id)) + '">Delete</button></div><div class="msg-text">' + esc(m.body) + '</div></div>'
    ).join("");
    msgStatus.textContent = "";
  }catch(e){
    msgStatus.textContent = "Couldn't load messages — tap Refresh to try again.";
  }
}
async function postMessage(){
  const name = msgName.value.trim(), body = msgText.value.trim();
  if(!body){ msgText.focus(); return; }
  msgSend.disabled = true;
  try{
    const res = await fetch("/api/messages", {
      method:"POST",
      headers:{"Content-Type":"application/json"},
      body: JSON.stringify({name:name, body:body})
    });
    if(!res.ok) throw new Error("bad status");
    try{ localStorage.setItem(NAME_KEY, name); }catch(e){}
    msgText.value = "";
    await loadMessages();
  }catch(e){
    msgStatus.textContent = "Couldn't post — check your connection and try again.";
  }
  msgSend.disabled = false;
}
async function deleteMessage(id){
  if(!messageAdminCode) return;
  if(!confirm("Delete this message?")) return;
  msgStatus.textContent = "Deleting message...";
  try{
    const res = await fetch("/api/messages", {
      method:"DELETE",
      headers:{"Content-Type":"application/json"},
      body: JSON.stringify({id:id, adminCode:messageAdminCode})
    });
    if(res.status === 401){
      try{ sessionStorage.removeItem(ADMIN_CODE_KEY); }catch(e){}
      loadAdminCode();
      msgStatus.textContent = "Admin code was not accepted.";
      return;
    }
    if(!res.ok) throw new Error("bad status");
    await loadMessages();
  }catch(e){
    msgStatus.textContent = "Couldn't delete message — try again.";
  }
}
